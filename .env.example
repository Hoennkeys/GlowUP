# Copie para .env e ajuste os valores.
# Secrets: lidos no servidor (nunca use prefixo VITE_).

# Obrigatório em produção (mín. 32 caracteres para sessão criptografada)
SESSION_SECRET=dev-secret-change-in-production-min-32-chars!!

# SQLite local (padrão em desenvolvimento)
SQLITE_PATH=data/vendapro.sqlite

# Postgres/Supabase (opcional — substitui SQLite quando definido)
# DATABASE_URL=postgresql://user:pass@localhost:5432/vendapro

# Ative a API + SQLite (Fase 7) — requer SESSION_SECRET
VITE_USE_SERVER_DB=true
USE_SERVER_DB=true

# ─── Plataforma Influenciadores (Etapas 5–8) ───────────────────────────────

# Feature flags (VITE_ = expostas ao client)
VITE_INFLUENCER_PLATFORM=true
VITE_CREATOR_DOMAIN_READ=true
VITE_PRESIGNED_UPLOADS=true
# VITE_REALTIME_NOTIFICATIONS=true
# VITE_SOCIAL_METRICS_SYNC=true
# VITE_STRIPE_SANDBOX=true

# Storage S3 (opcional — mock automático sem credenciais)
# AWS_S3_BUCKET=glowup-uploads
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# CDN_BASE_URL=https://cdn.glowup.app

# Redes sociais (opcional)
# INSTAGRAM_ACCESS_TOKEN=
# TIKTOK_CLIENT_KEY=
# YOUTUBE_API_KEY=

# Realtime Pusher (opcional)
# PUSHER_APP_ID=
# PUSHER_KEY=
# PUSHER_SECRET=
# PUSHER_CLUSTER=sa1

# Pagamentos Stripe (opcional)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
